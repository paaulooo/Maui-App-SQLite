<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppSQLite.Views.ListaProduto"
             Title="ListaProduto">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1" />
        <ToolbarItem Text="Novo" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label">
                <Setter Property="VerticalTextAlignment" Value="Center"></Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <StackLayout >

        <SearchBar
            x:Name="txt_search"
            Placeholder="Pesquisar Produtos"
            TextChanged="txt_search_TextChanged"
            Margin="-15,0,0,0"/>

        <Label Text="Filtrar por Categoria:" FontAttributes="Bold"/>
        <Picker
            x:Name="picker_category"
            Title="Selecione uma categoria"
            SelectedIndexChanged="picker_category_SelectedIndexChanged">
            <Picker.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>Todos</x:String>
                    <x:String>Eletrônicos</x:String>
                    <x:String>Roupas</x:String>
                    <x:String>Alimentos</x:String>
                </x:Array>
            </Picker.ItemsSource>

        </Picker>



        <Frame Padding="0" Margin="10" VerticalOptions="FillAndExpand">
            <ListView x:Name="lst_produto" 
                  IsPullToRefreshEnabled="True"
                  Refreshing="lst_produto_Refreshing"
                  ItemSelected="lst_produto_ItemSelected">
                <ListView.Header>
                    <Grid ColumnDefinitions="20, 100, 60, 80, 90"
                          Padding="5"
                          BackgroundColor="{StaticResource Gray100}">
                        <Label Text="ID" Grid.Column="0" FontAttributes="Bold" />
                        <Label Text="Nome" Grid.Column="1" FontAttributes="Bold" />
                        <Label Text="Qnt" Grid.Column="2" FontAttributes="Bold" />
                        <Label Text="Preço" Grid.Column="3" FontAttributes="Bold" />
                        <Label Text="Total" Grid.Column="4" FontAttributes="Bold" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <ViewCell.ContextActions>
                                <MenuItem Text="Remover" Clicked="MenuItem_Clicked" CommandParameter="{Binding .}"/>
                            </ViewCell.ContextActions>
                            <Grid ColumnDefinitions="20, 100, 60, 80, 100"
                                  Padding="5">
                                <Label Text="{Binding Id}" Grid.Column="0" FontAttributes="Bold" />
                                <Label Text="{Binding Name}" Grid.Column="1" FontAttributes="Bold" />
                                <Label Text="{Binding Quantity}" Grid.Column="2" FontAttributes="Bold" />
                                <Label Text="{Binding Price, StringFormat='{}{0:c}'}" Grid.Column="3" FontAttributes="Bold" />
                                <Label Text="{Binding TotalPrice, StringFormat='{}{0:c}'}" Grid.Column="4" FontAttributes="Bold" />
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Frame>

    </StackLayout>

</ContentPage>