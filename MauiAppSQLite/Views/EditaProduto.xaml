<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppSQLite.Views.EditaProduto"
             Title="{Binding Name}">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>


    <VerticalStackLayout Spacing="10" Margin="15">
        <Label 
        Text="Nome do Produto"
        VerticalOptions="Center" 
        HorizontalOptions="Center" />
        <Entry x:Name="txt_nome" Text="{Binding Name}"/>
        <Label 
        Text="Quantidade: "
        VerticalOptions="Center" 
        HorizontalOptions="Center" />
        <Entry x:Name="txt_quantidade" Text="{Binding Quantity}"/>
        <Label 
        Text="Preço Unitário"
        VerticalOptions="Center" 
        HorizontalOptions="Center" />
        <Entry x:Name="txt_preco" Text="{Binding Price}"/>
    </VerticalStackLayout>
</ContentPage>